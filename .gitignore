# OpenNeuroStudies .gitignore

# Cache and build directories
.cache/
.snakemake/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Exception: include source code lib directories
!code/src/openneuro_studies/lib/
!code/workflow/lib/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
code/.venv/
code/venv/
code/ENV/
code/env/

# Testing
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.cover

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs (now in .openneuro-studies subdataset)
# Keep *.log pattern for any stray logs outside subdataset
*.log

# Temporary files
*.tmp
*.bak

# Git annex
.git/annex/tmp/
.npm
.ssh/

# Editor and shell history files
.lesshst
.viminfo
.bash_history

# Test reports and temporary test files
*_TEST_REPORT.md
*_TEST_SUMMARY.md
*_test.tsv
studies_test.tsv

# Working notes (keep in working directory, not in git)
doc/note-todos/
