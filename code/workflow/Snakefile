"""OpenNeuroStudies Snakemake workflow.

This workflow extracts metadata from study datasets and aggregates
them into studies.tsv. It uses git SHA-based dependency tracking
to determine when recomputation is needed.

Usage (from repository root):
    # Run full workflow (all studies)
    snakemake -s code/workflow/Snakefile --cores 4

    # Process only specific studies
    snakemake -s code/workflow/Snakefile --cores 4 \
      --config studies="study-ds000001,study-ds000030"

    # Dry run - show what would be done
    snakemake -s code/workflow/Snakefile -n

    # Rerun based on git SHA changes (not just mtime)
    snakemake -s code/workflow/Snakefile --rerun-triggers params --cores 4

    # Force rerun of specific study
    snakemake -s code/workflow/Snakefile --forcerun .snakemake/extracted/study-ds000001.json

    # Clean up
    snakemake -s code/workflow/Snakefile --delete-all-output

    # Show DAG
    snakemake -s code/workflow/Snakefile --dag | dot -Tpng > dag.png
"""

import json
import sys
from pathlib import Path

# Add code/src to path for imports
sys.path.insert(0, str(Path(workflow.basedir).parent / "src"))

# Import workflow utilities
sys.path.insert(0, str(Path(workflow.basedir).parent))
from workflow.lib.git_utils import get_file_blob_sha, get_gitlink_sha, get_sourcedata_shas, get_tree_sha
from workflow.lib.provenance import ProvenanceManager, clean_stale_provenance

# ============================================================================
# Configuration
# ============================================================================

# All workflow-internal outputs live under .snakemake/ so they don't
# pollute the repository root. .snakemake/ is already gitignored.
#   .snakemake/extracted/{study}.json  — per-study intermediate
#   .snakemake/extracted/studies.tsv   — aggregated staging output
#   .snakemake/prov/                   — git-SHA provenance records
EXTRACTED_DIR = ".snakemake/extracted"
PROV_DIR = ".snakemake/prov"
WORKFLOW_TSV = f"{EXTRACTED_DIR}/studies.tsv"

# Columns populated by external tools (not this workflow) — preserve across merges
PRESERVED_COLS = {"bids_valid"}

# Extraction stages (columns depend on stage)
STAGES = {
    "basic": ["author_lead_raw", "author_senior_raw", "raw_version"],
    "counts": ["subjects_num", "sessions_num", "sessions_min", "sessions_max", "datatypes"],
    "sizes": ["bold_num", "t1w_num", "t2w_num", "bold_size", "t1w_size", "bold_size_max"],
    "imaging": ["bold_voxels_total", "bold_voxels_mean", "bold_duration_total", "bold_duration_mean"],
}

# ============================================================================
# Dynamic study discovery
# ============================================================================

def get_studies() -> list[str]:
    """Discover all study directories in repository root.

    Can be filtered via config: --config studies="study-ds000001,study-ds000030"
    """
    # Check if studies filter provided via config
    if "studies" in config:
        # Parse comma-separated study list
        studies = [s.strip() for s in config["studies"].split(",")]
        # Normalize: accept both "ds000001" and "study-ds000001"
        studies = [
            s if s.startswith("study-") else f"study-{s}"
            for s in studies
        ]
        # Verify they exist
        existing = []
        for study in studies:
            if Path(study).is_dir():
                existing.append(study)
            else:
                print(f"Warning: {study} not found, skipping", file=sys.stderr)
        return sorted(existing)

    # Default: discover all study directories
    studies = []
    for path in Path(".").iterdir():
        if path.is_dir() and path.name.startswith("study-"):
            studies.append(path.name)
    return sorted(studies)

STUDIES = get_studies()

# ============================================================================
# Provenance helpers
# ============================================================================

prov_manager = ProvenanceManager(PROV_DIR)

def get_study_deps(study: str) -> dict:
    """Get dependency SHAs for a study."""
    try:
        study_sha = get_gitlink_sha(study)
    except Exception:
        study_sha = get_tree_sha(study)

    return {
        "study_sha": study_sha,
        "sourcedata_shas": get_sourcedata_shas(study),
    }

def get_study_deps_with_version(study: str) -> dict:
    """Get dependency SHAs for a study with extraction version.

    Includes EXTRACTION_VERSION in params to trigger re-extraction
    when extraction logic changes.
    """
    from openneuro_studies.metadata.summary_extractor import EXTRACTION_VERSION

    return {
        **get_study_deps(study),
        "extraction_version": EXTRACTION_VERSION,
    }

# ============================================================================
# Rules
# ============================================================================

rule all:
    """Default target: merge extracted metadata into canonical studies.tsv and studies+derivatives.tsv."""
    input:
        "studies.tsv",
        "studies+derivatives.tsv"


rule extract_study:
    """Extract metadata for a single study.

    This rule produces a JSON file with all extracted metadata
    for one study. The params include git SHAs which trigger
    recomputation when dependencies change.

    Subdataset Management:
    - Initializes sourcedata subdatasets if needed (fail-fast on errors)
    - Initializes derivative subdatasets for metadata extraction (steps 3b/3c)
    - Deinitializes derivative subdatasets after extraction to free disk space
    - Sourcedata subdatasets remain initialized for future operations
    """
    output:
        json_file = f".snakemake/extracted/{{study}}.json"
    params:
        # Git SHAs and extraction version as params
        # Changes trigger rerun with --rerun-triggers params
        deps = lambda wc: get_study_deps_with_version(wc.study)
    run:
        from bids_studies.extraction import extract_study_stats
        from bids_studies.extraction.study import extract_all_derivatives_stats
        from bids_studies.extraction.tsv import write_tsv
        from openneuro_studies.lib.subdataset_manager import (
            get_uninitialized_sourcedata,
            get_uninitialized_derivatives,
            initialize_subdatasets,
            _deinitialize_single_subdataset,
        )
        from openneuro_studies.metadata.studies_plus_derivatives_tsv import (
            STUDIES_DERIVATIVES_COLUMNS,
            collect_derivative_cache_entries,
        )
        from openneuro_studies.metadata.studies_tsv import collect_study_metadata

        study_path = Path(wildcards.study)

        # 1. Find sourcedata subdatasets that need initialization
        to_init = get_uninitialized_sourcedata(study_path)

        # 2a. Initialize sourcedata if needed (FAIL FAST on operational errors)
        if to_init:
            logger.info(f"Initializing {len(to_init)} sourcedata subdatasets for {wildcards.study}")
            init_results = initialize_subdatasets(to_init, parent_path=Path("."))
            failed = [p for p, success in init_results.items() if not success]
            if failed:
                raise RuntimeError(
                    f"Failed to initialize required subdatasets for {wildcards.study}: {failed}. "
                    "This is an operational error - extraction cannot proceed without initialized sourcedata."
                )

        # 2b. Initialize derivative subdatasets for steps 3b/3c
        #     Track which we initialized so we can deinit them after extraction
        derivs_to_init = get_uninitialized_derivatives(study_path)
        derivs_we_initialized = []
        if derivs_to_init:
            logger.info(f"Initializing {len(derivs_to_init)} derivative subdatasets for {wildcards.study}")
            deriv_results = initialize_subdatasets(derivs_to_init, parent_path=Path("."))
            derivs_we_initialized = [p for p, success in deriv_results.items() if success]
            deriv_failed = [p for p, success in deriv_results.items() if not success]
            if deriv_failed:
                # Warn but don't fail — derivative extraction is best-effort
                logger.warning(
                    f"Failed to initialize {len(deriv_failed)} derivative subdatasets for {wildcards.study}: "
                    f"{[str(p) for p in deriv_failed]}"
                )

        # 3. Extract metadata (subdatasets now guaranteed initialized)
        # 3a. Generate hierarchical sourcedata TSV files (FR-042a/b)
        logger.info(f"Generating hierarchical sourcedata stats for {wildcards.study}")
        extract_study_stats(
            study_path,
            sourcedata_subdir="sourcedata",
            include_imaging=True,
            write_files=True,
        )

        # 3b. Generate combined derivative TSV files at derivatives/ level (FR-042e)
        derivatives_dir = study_path / "derivatives"
        if derivatives_dir.exists():
            source_id = study_path.name.replace("study-", "")
            logger.info(f"Generating hierarchical derivative stats for {wildcards.study}")
            extract_all_derivatives_stats(
                derivatives_dir, source_id=source_id, write_files=True
            )

        # 3c. Cache derivative metadata for studies+derivatives.tsv (FR-042h)
        derivatives_cache = collect_derivative_cache_entries(study_path)
        cache_path = Path(f".snakemake/extracted/{wildcards.study}.derivatives.tsv")
        cache_path.parent.mkdir(parents=True, exist_ok=True)
        write_tsv(cache_path, STUDIES_DERIVATIVES_COLUMNS, derivatives_cache)
        if derivatives_cache:
            logger.info(f"Cached {len(derivatives_cache)} derivative entries for {wildcards.study}")

        # 3d. Deinitialize derivative subdatasets we initialized (free disk space)
        #     Sourcedata subdatasets remain initialized for future operations.
        if derivs_we_initialized:
            logger.info(f"Deinitializing {len(derivs_we_initialized)} derivative subdatasets for {wildcards.study}")
            for deriv_path in derivs_we_initialized:
                _deinitialize_single_subdataset(deriv_path, parent_path=Path("."))

        # 3e. Extract study-level metadata
        result = collect_study_metadata(study_path, stage="imaging")
        Path(output.json_file).parent.mkdir(parents=True, exist_ok=True)
        with open(output.json_file, "w") as f:
            json.dump(result, f, indent=2)
        prov_manager.record(output.json_file, "extract_study", params.deps)
        logger.info(f"Extracted metadata for {wildcards.study}")


rule aggregate_studies:
    """Aggregate per-study JSONs into .snakemake/extracted/studies.tsv.

    NOTE: This does NOT write to the canonical studies.tsv, which is
    managed by `openneuro-studies metadata generate` and contains
    additional columns (name, version, bids_version, license, authors,
    source_count, derivative_ids, bids_valid, bold_voxels, etc.).

    All outputs stay under .snakemake/ (gitignored); the canonical
    studies.tsv is updated separately by merging from sourcedata.tsv.
    """
    input:
        study_jsons = expand(".snakemake/extracted/{study}.json", study=STUDIES)
    output:
        tsv = WORKFLOW_TSV
    params:
        # Track aggregate dependencies
        all_deps = lambda wc, input: {
            Path(f).stem: get_study_deps(Path(f).stem)
            for f in input.study_jsons
        }
    run:
        import pandas as pd

        rows = []
        for json_file in input.study_jsons:
            with open(json_file) as f:
                data = json.load(f)
            rows.append(data)

        # Create DataFrame and sort
        df = pd.DataFrame(rows)
        if "study_id" in df.columns:
            df = df.sort_values("study_id")
            cols = ["study_id"] + [c for c in df.columns if c != "study_id"]
            df = df[cols]

        Path(output.tsv).parent.mkdir(parents=True, exist_ok=True)
        df.to_csv(output.tsv, sep="\t", index=False)

        # Record provenance
        prov_manager.record(
            output_path=output.tsv,
            rule_name="aggregate_studies",
            dependencies=params.all_deps,
        )

        print(f"Aggregated {len(rows)} studies into {output.tsv}")
        print(f"NOTE: Canonical studies.tsv is NOT modified. Use 'openneuro-studies metadata generate' to update it.")


rule merge_into_canonical:
    """Merge per-study extracted JSONs into the canonical studies.tsv.

    Reads .snakemake/extracted/{study}.json for every study, updates the
    canonical studies.tsv with all computed columns while preserving
    bids_valid (set by openneuro-studies validate).

    Trigger conditions:
      - mtime-based (default): any per-study JSON is newer than studies.tsv
      - SHA-based (preferred): any study's gitlink SHA changed
        → snakemake -s code/workflow/Snakefile --rerun-triggers params
    """
    input:
        study_jsons = expand(".snakemake/extracted/{study}.json", study=STUDIES)
    output:
        canonical = "studies.tsv"
    params:
        all_deps = lambda wc, input: {
            Path(f).stem: get_study_deps(Path(f).stem)
            for f in input.study_jsons
        },
        # Track canonical SHA so params change when bids_valid is updated
        # externally — lets user trigger a re-merge if columns were reset.
        canonical_sha = lambda wc: (
            get_file_blob_sha("studies.tsv") if Path("studies.tsv").exists() else "absent"
        ),
    run:
        from openneuro_studies.metadata.studies_tsv import merge_extracts_into_studies_tsv

        count = merge_extracts_into_studies_tsv(
            canonical_path=Path(output.canonical),
            extracted_jsons=[Path(f) for f in input.study_jsons],
            preserved_cols=PRESERVED_COLS,
        )

        prov_manager.record(output.canonical, "merge_into_canonical", params.all_deps)
        print(f"Updated {output.canonical}: {count} studies")


rule merge_derivatives_tsv:
    """Merge per-study derivative caches into canonical studies+derivatives.tsv.

    Reads .snakemake/extracted/{study}.derivatives.tsv files (produced by
    extract_study rule) and merges them into the canonical studies+derivatives.tsv.
    This is a fast file-merge operation (seconds) per FR-042h.

    Preserves existing entries for studies that don't have fresh cache files,
    so incremental extraction (subset of studies) doesn't lose data.
    """
    input:
        # Depend on per-study JSON files (produced alongside .derivatives.tsv)
        study_jsons = expand(".snakemake/extracted/{study}.json", study=STUDIES)
    output:
        canonical = "studies+derivatives.tsv"
    run:
        from openneuro_studies.metadata.studies_plus_derivatives_tsv import (
            generate_studies_derivatives_json,
            generate_studies_derivatives_tsv,
        )

        study_paths = [Path(s) for s in STUDIES]
        generate_studies_derivatives_tsv(
            studies=study_paths,
            output_path=Path(output.canonical),
            cache_dir=Path(EXTRACTED_DIR),
        )
        generate_studies_derivatives_json(Path("studies+derivatives.json"))
        print(f"Merged derivatives into {output.canonical}")


rule clean_provenance:
    """Remove stale provenance entries for deleted outputs."""
    run:
        # Get current outputs
        existing = set()
        for study in STUDIES:
            json_file = f".snakemake/extracted/{study}.json"
            if Path(json_file).exists():
                existing.add(json_file)
        if Path(WORKFLOW_TSV).exists():
            existing.add(WORKFLOW_TSV)

        # Clean stale entries
        stale = clean_stale_provenance(PROV_DIR, existing)
        if stale:
            print(f"Removed {len(stale)} stale provenance entries")
        else:
            print("No stale provenance entries found")


rule show_provenance:
    """Show provenance summary for all outputs."""
    run:
        from workflow.lib.provenance import get_provenance_summary

        summary = get_provenance_summary(PROV_DIR)
        print(f"\nProvenance Summary")
        print(f"==================")
        print(f"Total outputs tracked: {summary['total_outputs']}")
        print(f"Last updated: {summary['updated']}")
        print(f"\nOutputs:")
        for output in sorted(summary['outputs']):
            print(f"  - {output}")


rule show_deps:
    """Show current dependency SHAs for all studies."""
    run:
        print("\nStudy Dependencies (git SHAs)")
        print("=" * 60)
        for study in STUDIES:
            deps = get_study_deps(study)
            print(f"\n{study}:")
            print(f"  study_sha: {deps['study_sha'][:12]}...")
            if deps['sourcedata_shas']:
                print("  sourcedata:")
                for src, sha in deps['sourcedata_shas'].items():
                    print(f"    {src}: {sha[:12]}...")


