"""OpenNeuroStudies Snakemake workflow.

This workflow extracts metadata from study datasets and aggregates
them into studies.tsv. It uses git SHA-based dependency tracking
to determine when recomputation is needed.

Usage (from repository root):
    # Run full workflow
    snakemake -s code/workflow/Snakefile --cores 4

    # Dry run - show what would be done
    snakemake -s code/workflow/Snakefile -n

    # Rerun based on git SHA changes (not just mtime)
    snakemake -s code/workflow/Snakefile --rerun-triggers params

    # Force rerun of specific study
    snakemake -s code/workflow/Snakefile --forcerun .snakemake/extracted/study-ds000001.json

    # Clean up
    snakemake -s code/workflow/Snakefile --delete-all-output

    # Show DAG
    snakemake -s code/workflow/Snakefile --dag | dot -Tpng > dag.png
"""

import json
import sys
from pathlib import Path

# Add code/src to path for imports
sys.path.insert(0, str(Path(workflow.basedir).parent / "src"))

# Import workflow utilities
sys.path.insert(0, str(Path(workflow.basedir).parent))
from workflow.lib.git_utils import get_file_blob_sha, get_gitlink_sha, get_sourcedata_shas, get_tree_sha
from workflow.lib.provenance import ProvenanceManager, clean_stale_provenance

# ============================================================================
# Configuration
# ============================================================================

# All workflow-internal outputs live under .snakemake/ so they don't
# pollute the repository root. .snakemake/ is already gitignored.
#   .snakemake/extracted/{study}.json  — per-study intermediate
#   .snakemake/extracted/studies.tsv   — aggregated staging output
#   .snakemake/prov/                   — git-SHA provenance records
EXTRACTED_DIR = ".snakemake/extracted"
PROV_DIR = ".snakemake/prov"
WORKFLOW_TSV = f"{EXTRACTED_DIR}/studies.tsv"

# Columns populated by external tools (not this workflow) — preserve across merges
PRESERVED_COLS = {"bids_valid"}

# Extraction stages (columns depend on stage)
STAGES = {
    "basic": ["author_lead_raw", "author_senior_raw", "raw_version"],
    "counts": ["subjects_num", "sessions_num", "sessions_min", "sessions_max", "datatypes"],
    "sizes": ["bold_num", "t1w_num", "t2w_num", "bold_size", "t1w_size", "bold_size_max"],
    "imaging": ["bold_voxels_total", "bold_voxels_mean", "bold_duration_total", "bold_duration_mean"],
}

# ============================================================================
# Dynamic study discovery
# ============================================================================

def get_studies() -> list[str]:
    """Discover all study directories in repository root."""
    studies = []
    for path in Path(".").iterdir():
        if path.is_dir() and path.name.startswith("study-"):
            studies.append(path.name)
    return sorted(studies)

STUDIES = get_studies()

# ============================================================================
# Provenance helpers
# ============================================================================

prov_manager = ProvenanceManager(PROV_DIR)

def get_study_deps(study: str) -> dict:
    """Get dependency SHAs for a study."""
    try:
        study_sha = get_gitlink_sha(study)
    except Exception:
        study_sha = get_tree_sha(study)

    return {
        "study_sha": study_sha,
        "sourcedata_shas": get_sourcedata_shas(study),
    }

# ============================================================================
# Rules
# ============================================================================

rule all:
    """Default target: merge extracted metadata into canonical studies.tsv."""
    input:
        "studies.tsv"


rule extract_study:
    """Extract metadata for a single study.

    This rule produces a JSON file with all extracted metadata
    for one study. The params include git SHAs which trigger
    recomputation when dependencies change.
    """
    output:
        json_file = f".snakemake/extracted/{{study}}.json"
    params:
        # Git SHAs as params - changes trigger rerun with --rerun-triggers params
        deps = lambda wc: get_study_deps(wc.study)
    run:
        from openneuro_studies.metadata.studies_tsv import collect_study_metadata

        study_path = Path(wildcards.study)

        # Extract all columns (collect_study_metadata sets study_id internally)
        result = collect_study_metadata(study_path, stage="imaging")

        # Ensure output directory exists
        Path(output.json_file).parent.mkdir(parents=True, exist_ok=True)

        # Write result
        with open(output.json_file, "w") as f:
            json.dump(result, f, indent=2)

        # Record provenance
        prov_manager.record(
            output_path=output.json_file,
            rule_name="extract_study",
            dependencies=params.deps,
        )

        print(f"Extracted metadata for {wildcards.study}")


rule aggregate_studies:
    """Aggregate per-study JSONs into .snakemake/extracted/studies.tsv.

    NOTE: This does NOT write to the canonical studies.tsv, which is
    managed by `openneuro-studies metadata generate` and contains
    additional columns (name, version, bids_version, license, authors,
    source_count, derivative_ids, bids_valid, bold_voxels, etc.).

    All outputs stay under .snakemake/ (gitignored); the canonical
    studies.tsv is updated separately by merging from sourcedata.tsv.
    """
    input:
        study_jsons = expand(".snakemake/extracted/{study}.json", study=STUDIES)
    output:
        tsv = WORKFLOW_TSV
    params:
        # Track aggregate dependencies
        all_deps = lambda wc, input: {
            Path(f).stem: get_study_deps(Path(f).stem)
            for f in input.study_jsons
        }
    run:
        import pandas as pd

        rows = []
        for json_file in input.study_jsons:
            with open(json_file) as f:
                data = json.load(f)
            rows.append(data)

        # Create DataFrame and sort
        df = pd.DataFrame(rows)
        if "study_id" in df.columns:
            df = df.sort_values("study_id")
            cols = ["study_id"] + [c for c in df.columns if c != "study_id"]
            df = df[cols]

        Path(output.tsv).parent.mkdir(parents=True, exist_ok=True)
        df.to_csv(output.tsv, sep="\t", index=False)

        # Record provenance
        prov_manager.record(
            output_path=output.tsv,
            rule_name="aggregate_studies",
            dependencies=params.all_deps,
        )

        print(f"Aggregated {len(rows)} studies into {output.tsv}")
        print(f"NOTE: Canonical studies.tsv is NOT modified. Use 'openneuro-studies metadata generate' to update it.")


rule merge_into_canonical:
    """Merge per-study extracted JSONs into the canonical studies.tsv.

    Reads .snakemake/extracted/{study}.json for every study, updates the
    canonical studies.tsv with all computed columns while preserving
    bids_valid (set by openneuro-studies validate).

    Trigger conditions:
      - mtime-based (default): any per-study JSON is newer than studies.tsv
      - SHA-based (preferred): any study's gitlink SHA changed
        → snakemake -s code/workflow/Snakefile --rerun-triggers params
    """
    input:
        study_jsons = expand(".snakemake/extracted/{study}.json", study=STUDIES)
    output:
        canonical = "studies.tsv"
    params:
        all_deps = lambda wc, input: {
            Path(f).stem: get_study_deps(Path(f).stem)
            for f in input.study_jsons
        },
        # Track canonical SHA so params change when bids_valid is updated
        # externally — lets user trigger a re-merge if columns were reset.
        canonical_sha = lambda wc: (
            get_file_blob_sha("studies.tsv") if Path("studies.tsv").exists() else "absent"
        ),
    run:
        import csv
        from openneuro_studies.metadata.studies_tsv import STUDIES_COLUMNS

        canonical_path = Path(output.canonical)

        # Load existing studies.tsv to preserve PRESERVED_COLS (e.g. bids_valid)
        existing = {}
        if canonical_path.exists():
            with open(canonical_path, newline="") as f:
                for row in csv.DictReader(f, delimiter="\t"):
                    existing[row["study_id"]] = dict(row)

        # Overlay extracted data, restoring preserved columns
        for json_file in input.study_jsons:
            with open(json_file) as f:
                data = json.load(f)
            sid = data["study_id"]
            if sid in existing:
                for col in PRESERVED_COLS:
                    data.setdefault(col, existing[sid].get(col, "n/a"))
            existing[sid] = data

        # Write canonical file in defined column order
        rows = [existing[sid] for sid in sorted(existing)]
        with open(canonical_path, "w", newline="") as f:
            writer = csv.DictWriter(
                f, fieldnames=STUDIES_COLUMNS, delimiter="\t", extrasaction="ignore"
            )
            writer.writeheader()
            writer.writerows(rows)

        prov_manager.record(output.canonical, "merge_into_canonical", params.all_deps)
        print(f"Updated {output.canonical}: {len(rows)} studies")


rule clean_provenance:
    """Remove stale provenance entries for deleted outputs."""
    run:
        # Get current outputs
        existing = set()
        for study in STUDIES:
            json_file = f".snakemake/extracted/{study}.json"
            if Path(json_file).exists():
                existing.add(json_file)
        if Path(STUDIES_TSV).exists():
            existing.add(STUDIES_TSV)

        # Clean stale entries
        stale = clean_stale_provenance(PROV_DIR, existing)
        if stale:
            print(f"Removed {len(stale)} stale provenance entries")
        else:
            print("No stale provenance entries found")


rule show_provenance:
    """Show provenance summary for all outputs."""
    run:
        from workflow.lib.provenance import get_provenance_summary

        summary = get_provenance_summary(PROV_DIR)
        print(f"\nProvenance Summary")
        print(f"==================")
        print(f"Total outputs tracked: {summary['total_outputs']}")
        print(f"Last updated: {summary['updated']}")
        print(f"\nOutputs:")
        for output in sorted(summary['outputs']):
            print(f"  - {output}")


rule show_deps:
    """Show current dependency SHAs for all studies."""
    run:
        print("\nStudy Dependencies (git SHAs)")
        print("=" * 60)
        for study in STUDIES:
            deps = get_study_deps(study)
            print(f"\n{study}:")
            print(f"  study_sha: {deps['study_sha'][:12]}...")
            if deps['sourcedata_shas']:
                print("  sourcedata:")
                for src, sha in deps['sourcedata_shas'].items():
                    print(f"    {src}: {sha[:12]}...")


